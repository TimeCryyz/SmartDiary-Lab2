@model IEnumerable<MvcLab1.Models.Game>

@{
    ViewData["Title"] = "Управление играми";
}

<h1>Управление играми</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить игру</a>
    <a asp-action="Multiplayer" class="btn btn-success">Мультиплеерные игры</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Жанр</th>
            <th>Платформа</th>
            <th>Год</th>
            <th>Рейтинг</th>
            <th>Цена</th>
            <th>Мультиплеер</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Title</td>
                <td>@item.Genre</td>
                <td>@item.Platform</td>
                <td>@item.ReleaseYear</td>
                <td>@item.Rating</td>
                <td>@item.Price.ToString("C")</td>
                <td>@(item.IsMultiplayer ? "Да" : "Нет")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Детали</a> |
                    <a asp-action="Edit" asp-route-id="@item.Id">Изменить</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                 </td>
            </tr>
        }
    </tbody>
</table>