@model MvcLab1.Models.Game

@{
    ViewData["Title"] = "Удаление игры";
}

<h1>Удаление игры</h1>

<div class="alert alert-danger">
    <h3>Вы уверены, что хотите удалить эту игру?</h3>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Название</dt>
        <dd class="col-sm-10">@Model.Title</dd>
        <dt class="col-sm-2">Жанр</dt>
        <dd class="col-sm-10">@Model.Genre</dd>
        <dt class="col-sm-2">Платформа</dt>
        <dd class="col-sm-10">@Model.Platform</dd>
        <dt class="col-sm-2">Рейтинг</dt>
        <dd class="col-sm-10">@Model.Rating</dd>
    </dl>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>