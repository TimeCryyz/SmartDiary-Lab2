@{
    ViewData["Title"] = "Ошибка";
}

<div style="background-color: #f8d7da; color: #721c24; padding: 30px; border-radius: 8px; text-align: center; margin: 50px auto; max-width: 600px;">
    <h1>⚠️ Ошибка</h1>
    <p style="font-size: 18px;">@ViewBag.ErrorMessage</p>
    <a href="/Gaming/Games" style="display: inline-block; margin-top: 20px; padding: 10px 30px; background-color: #007bff; color: white; text-decoration: none; border-radius: 5px;">Вернуться в каталог</a>
</div>