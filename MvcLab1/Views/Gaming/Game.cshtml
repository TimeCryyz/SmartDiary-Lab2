@{
    ViewData["Title"] = $"Информация об игре";
}

<h1>@ViewBag.Title</h1>

<div style="background-color: #f0f8ff; padding: 25px; border-radius: 10px; margin: 20px 0;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div>
            <h3>Основная информация</h3>
            <p><strong>Название:</strong> @ViewBag.Title</p>
            <p><strong>Жанр:</strong> @ViewBag.Genre</p>
            <p><strong>Рейтинг:</strong> 
                <span style="color: @(ViewBag.Rating >= 9 ? "green" : ViewBag.Rating >= 8 ? "orange" : "red");">
                    @ViewBag.Rating/10
                </span>
                @for (int i = 1; i <= 5; i++)
                {
                    if (i <= Math.Round(ViewBag.Rating / 2))
                    {
                        <span style="color: gold; font-size: 20px;">★</span>
                    }
                    else
                    {
                        <span style="color: #ccc; font-size: 20px;">★</span>
                    }
                }
            </p>
            <p><strong>Разработчик:</strong> @ViewBag.Developer</p>
            <p><strong>Год выпуска:</strong> @ViewBag.Year</p>
        </div>
        <div>
            <h3>Описание</h3>
            <p style="line-height: 1.6;">@ViewBag.Description</p>
        </div>
    </div>
    
    <hr>
    
    <h3>Доступные платформы</h3>
    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
        @foreach (var platform in ViewBag.Platforms)
        {
            <span style="padding: 5px 15px; background-color: #007bff; color: white; border-radius: 20px;">@platform</span>
        }
    </div>
</div>

<div style="margin-top: 20px;">
    <a href="/Gaming/Games" style="padding: 10px 20px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 5px;">← Назад к каталогу</a>
    <a href="/Gaming/SystemRequirements?gameTitle=@ViewBag.Title" style="padding: 10px 20px; background-color: #28a745; color: white; text-decoration: none; border-radius: 5px; margin-left: 10px;">Системные требования</a>
</div>