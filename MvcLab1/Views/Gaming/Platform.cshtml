@{
    ViewData["Title"] = $"Игры на платформе {ViewBag.Platform}";
}

<h1>Игры на платформе @ViewBag.Platform</h1>

<p>Найдено игр: <strong>@ViewBag.GamesCount</strong></p>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 30px;">
    @foreach (var game in ViewBag.Games)
    {
        <div style="border: 1px solid #ddd; border-radius: 8px; padding: 15px;">
            <h3 style="margin-top: 0;">@game.Title</h3>
            <p><strong>Жанр:</strong> @game.Genre</p>
            <p><strong>Рейтинг:</strong> @game.Rating/10</p>
            <a href="/Gaming/Game?gameTitle=@game.Title" style="display: inline-block; padding: 5px 10px; background-color: #007bff; color: white; text-decoration: none; border-radius: 4px;">Подробнее</a>
        </div>
    }
</div>

<div style="margin-top: 20px;">
    <a href="/Gaming/Games" style="padding: 10px 20px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 5px;">← Назад к каталогу</a>
</div>