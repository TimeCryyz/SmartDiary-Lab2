@model MvcLab1.Models.Product

@{
    ViewData["Title"] = "Удаление товара";
}

<h1>Удаление товара</h1>

<div class="alert alert-danger">
    <h3>Вы уверены, что хотите удалить этот товар?</h3>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Название</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Категория</dt>
        <dd class="col-sm-10">@Model.Category</dd>
        <dt class="col-sm-2">Цена</dt>
        <dd class="col-sm-10">@Model.Price.ToString("C")</dd>
    </dl>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>